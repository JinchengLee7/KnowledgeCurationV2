# Normalize line endings to LF in the repo; checkout as-is on Windows
* text=auto eol=lf
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.tex text eol=lf
*.cfg text eol=lf

# Binaries — no line-ending conversion
*.pdf binary
*.sqlite3 binary
*.png binary
*.jpg binary
