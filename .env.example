# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your real API key.

# Semantic Scholar API key (optional — raises free-tier rate limits significantly)
# Get yours at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=your_key_here

# Override the API base URL (rarely needed)
# SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1

# HTTP request timeout in seconds (default 30)
# REQUEST_TIMEOUT_S=30

# Hard cap on total candidates per run (default 200)
# MAX_CANDIDATES_PER_RUN=200

# Results requested per query (default 50, API max 100)
# TOP_K_PER_QUERY=50

# SQLite database path (default data/baseline/baseline.sqlite3)
# BASELINE_SQLITE_PATH=data/baseline/baseline.sqlite3
